# ============================================
# InferOps — Environment Configuration
# ============================================
# Copy this to .env and fill in your values.
# The app runs in MOCK DATA mode by default (no keys required).

# --- BFF Server ---
BFF_PORT=4000
FRONTEND_URL=http://localhost:3000

# --- AI / LLM Integration ---
# Leave blank to use mock data mode
AI_API_KEY=
AI_ENDPOINT=https://your-resource.openai.azure.com/
AI_MODEL=gpt-4

# --- GitHub Actions API ---
GITHUB_TOKEN=
GITHUB_ORG=your-org

# --- Azure Monitor ---
AZURE_MONITOR_CONNECTION_STRING=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# --- Next.js Frontend ---
NEXT_PUBLIC_BFF_URL=http://localhost:4000
