{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@inferops/bff": ["packages/bff/src"],
      "@inferops/ai-engine": ["packages/ai-engine/src"],
      "@inferops/ui-system": ["packages/ui-system/src"]
    }
  },
  "exclude": ["node_modules"]
}
